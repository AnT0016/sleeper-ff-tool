# data_cache/ IS committed (our computed parquet/sqlite artifacts). Only volatile,
# re-fetchable download caches are ignored: the requests-cache HTTP store and the
# nflreadpy raw download cache. (gitignore: trailing inline comments are NOT supported.)
data_cache/http_cache.sqlite
data_cache/http_cache.sqlite-*
data_cache/nflverse_cache/
